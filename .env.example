# ══════════════════════════════════════════════════════════════
# Réseaux-Résident — Variables d'environnement
# ══════════════════════════════════════════════════════════════
# Ce fichier est committé dans git (SANS valeurs réelles).
# Pour le dev local : copier vers .env.local
# Pour Vercel : configurer dans Settings > Environment Variables
# ══════════════════════════════════════════════════════════════


# ── FRONTEND (Vite — préfixe VITE_ obligatoire) ──────────────
# Exposées dans le bundle JS — PAS de secrets ici.

# Supabase — Dashboard > Settings > API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...votre-anon-key

# Stripe — Dashboard > Developers > API keys > Publishable key
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# URL de l'application
VITE_APP_URL=http://localhost:3000

# Sentry (optionnel) — https://sentry.io > Project > Client Keys
VITE_SENTRY_DSN=
VITE_ENV=development
VITE_APP_VERSION=1.0.0

# PostHog Analytics (optionnel) — https://posthog.com > Project Settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com


# ── SERVERLESS (Vercel — process.env) ─────────────────────────
# Jamais exposées côté client. Uniquement dans api/.

# Supabase — Dashboard > Settings > API > service_role key (SECRET)
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre-service-role-key

# Stripe — Dashboard > Developers > API keys > Secret key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Premium — IDs des Price créés dans Stripe (optionnel)
STRIPE_PRICE_ESSENTIEL=price_...
STRIPE_PRICE_PREMIUM=price_...

# Resend (emails) — https://resend.com > API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@reseaux-resident.fr

# API INSEE Sirene — https://api.insee.fr/catalogue/
INSEE_API_KEY=

# Clé de synchronisation SimplyFoot / SimplyRugby (interne)
RR_SYNC_API_KEY=

# URL publique de l'application (pour emails et webhooks)
APP_URL=https://reseaux-resident.fr
